{
    "name": "frontend-gis-ia",
    "private": true,
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc && vite build",
        "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
        "preview": "vite preview",
        "clean": "rm -rf node_modules/.vite && rm -rf dist",
        "clean:win": "taskkill /f /im node.exe & rmdir /s /q node_modules\\.vite & rmdir /s /q dist",
        "dev:fresh": "npm run clean:win && npm install && npm run dev",
        "dev:clean": "npm run clean && npm run dev",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage"
    },
    "dependencies": {
        "@turf/turf": "^6.5.0",
        "@types/shpjs": "^3.4.7",
        "axios": "^1.6.0",
        "leaflet": "^1.9.4",
        "leaflet-draw": "^1.0.4",
        "leaflet-geometryutil": "^0.10.3",
        "react": "^18.2.0",
        "react-beautiful-dnd": "^13.1.1",
        "react-dom": "^18.2.0",
        "react-leaflet": "^4.2.1",
        "shpjs": "^6.2.0"
    },
    "devDependencies": {
        "@babel/core": "^7.29.0",
        "@babel/preset-env": "^7.29.0",
        "@babel/preset-react": "^7.28.5",
        "@babel/preset-typescript": "^7.28.5",
        "@jest/globals": "^30.2.0",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/jest": "^30.0.0",
        "@types/leaflet": "^1.9.8",
        "@types/leaflet-draw": "^1.0.13",
        "@types/react": "^18.2.37",
        "@types/react-beautiful-dnd": "^13.1.8",
        "@types/react-dom": "^18.2.15",
        "@typescript-eslint/eslint-plugin": "^6.10.0",
        "@typescript-eslint/parser": "^6.10.0",
        "@vitejs/plugin-react": "^4.1.1",
        "autoprefixer": "^10.4.16",
        "babel-jest": "^30.2.0",
        "eslint": "^8.53.0",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^4.6.2",
        "eslint-plugin-react-refresh": "^0.4.4",
        "identity-obj-proxy": "^3.0.0",
        "jest": "^30.2.0",
        "jest-environment-jsdom": "^30.2.0",
        "postcss": "^8.4.31",
        "tailwindcss": "^3.3.5",
        "ts-jest": "^29.4.6",
        "typescript": "^5.2.2",
        "vite": "^5.0.0"
    }
}
